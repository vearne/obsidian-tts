		"@typescript-eslint/parser": "^7.0.0",
		"builtin-modules": "^3.3.0",
		"edge-tts-universal": "^1.4.0",
		"esbuild": "^0.25.12",
		"obsidian": "^1.13.0",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3"
